{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "dialog:default",
    "process:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
