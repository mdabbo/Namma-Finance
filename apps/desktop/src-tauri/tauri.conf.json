{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NAMAA Finance",
  "version": "0.6.2",
  "identifier": "com.mepfinance.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NAMAA Finance",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Arabic", "English"],
        "installMode": "currentUser"
      }
    }
  }
}
